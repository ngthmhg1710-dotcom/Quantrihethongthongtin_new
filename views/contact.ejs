<%- include("partials/header") %>
<section class="contact-hero">
  <h1>Get in Touch</h1>
  <p>Have a question? We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
</section>

<section class="section contact-info-grid">
  <article class="card contact-info-card">
    <span class="contact-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <rect x="3" y="5.5" width="18" height="13" rx="2"></rect>
        <path d="M4.2 7l7.8 5.8L19.8 7"></path>
      </svg>
    </span>
    <h3>Email Us</h3>
    <p>hello@glow.com</p>
    <p>support@glow.com</p>
  </article>
  <article class="card contact-info-card">
    <span class="contact-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <path d="M21 16.2v2a1.8 1.8 0 0 1-2 1.8A17.7 17.7 0 0 1 11.3 17a17.4 17.4 0 0 1-5.3-5.3A17.7 17.7 0 0 1 3 4.9a1.8 1.8 0 0 1 1.8-2h2a1.8 1.8 0 0 1 1.8 1.5c.1 1 .3 2 .6 2.9a1.8 1.8 0 0 1-.4 1.9L8 10a14.4 14.4 0 0 0 6 6l.8-.8a1.8 1.8 0 0 1 1.9-.4c.9.3 1.9.5 2.9.6a1.8 1.8 0 0 1 1.4 1.8z"></path>
      </svg>
    </span>
    <h3>Call Us</h3>
    <p>+1 (555) 123-4567</p>
    <p>Mon-Fri, 9am-6pm EST</p>
  </article>
  <article class="card contact-info-card">
    <span class="contact-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <path d="M12 21s-6.5-5.1-6.5-11A6.5 6.5 0 1 1 18.5 10c0 5.9-6.5 11-6.5 11z"></path>
        <circle cx="12" cy="10" r="2.3"></circle>
      </svg>
    </span>
    <h3>Visit Us</h3>
    <p>123 Beauty Avenue</p>
    <p>New York, NY 10001</p>
  </article>
</section>

<section class="section contact-main">
  <div class="contact-image card">
    <img src="https://images.unsplash.com/photo-1571781926291-c477ebfd024b?auto=format&fit=crop&w=1000&q=80" alt="Skincare model with avocado mask" />
  </div>
  <div class="card contact-form-card">
    <h2>Send us a Message</h2>
    <form>
      <label for="contact-name">Your Name</label>
      <input id="contact-name" type="text" placeholder="Jane Doe" />
      <label for="contact-email">Email Address</label>
      <input id="contact-email" type="email" placeholder="jane@example.com" />
      <label for="contact-subject">Subject</label>
      <input id="contact-subject" type="text" placeholder="How can we help?" />
      <label for="contact-message">Message</label>
      <textarea id="contact-message" rows="4" placeholder="Tell us more about your inquiry..."></textarea>
      <button class="btn btn-primary contact-submit" type="button">Send Message</button>
    </form>
  </div>
</section>

<section class="contact-faq">
  <div class="container">
    <h2>Frequently Asked Questions</h2>
    <article class="faq-item">
      <h3>What are your shipping options?</h3>
      <p>We offer free shipping on orders over $50. Standard shipping takes 5-7 business days, and express shipping is available for 2-3 day delivery.</p>
    </article>
    <article class="faq-item">
      <h3>What is your return policy?</h3>
      <p>We offer a 30-day money-back guarantee on all products. If you're not satisfied, you can return any unopened product for a full refund.</p>
    </article>
    <article class="faq-item">
      <h3>Are your products cruelty-free?</h3>
      <p>Yes. All Glow products are 100% cruelty-free and never tested on animals, with formulas developed to be gentle on skin.</p>
    </article>
  </div>
</section>
<%- include("partials/footer") %>
