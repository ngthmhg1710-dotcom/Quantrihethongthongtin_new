<%- include("partials/header") %>
<section class="section">
  <h1>Admin Dashboard</h1>
  <p>Total Revenue: <strong>$<%= revenue.toFixed(2) %></strong></p>

  <div class="two-col" style="margin-top:20px;">
    <div class="card">
      <h2>Add Product</h2>
      <form action="/admin/products" method="post">
        <input name="name" placeholder="Name" required />
        <input name="price" type="number" step="0.01" placeholder="Price" required />
        <input name="image" placeholder="Image URL" required />
        <input name="badges" placeholder="Badges (comma separated)" required />
        <textarea name="description" placeholder="Description" required></textarea>
        <button class="btn btn-primary" type="submit">Create</button>
      </form>
    </div>
    <div class="card">
      <h2>Orders</h2>
      <p><strong><%= orders.length %></strong> total orders</p>
    </div>
  </div>

  <h2 style="margin-top:24px;">Products</h2>
  <table>
    <thead><tr><th>Name</th><th>Price</th><th>Action</th></tr></thead>
    <tbody>
      <% products.forEach((product) => { %>
        <tr>
          <td><%= product.name %></td>
          <td>$<%= product.price.toFixed(2) %></td>
          <td>
            <form action="/admin/products/<%= product._id %>?_method=DELETE" method="post">
              <button class="btn btn-soft" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include("partials/footer") %>
